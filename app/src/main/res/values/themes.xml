<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LVHS" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/forest_green</item>
        <item name="colorPrimaryDark">@color/forest_dark</item>
        <item name="android:statusBarColor">@color/forest_green</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
